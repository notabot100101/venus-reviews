# Venus Reviews - Hostinger .htaccess
RewriteEngine On
DirectoryIndex index.html
Options -Indexes

# Clean URLs - add .html extension for existing files only
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Custom error pages
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# Redirect old WordPress-style URLs to new structure
Redirect 301 /privacy-policy/ /privacy/
Redirect 301 /reviews/ /products/
Redirect 301 /blog/ /guides/
Redirect 301 /category/vibrators/ /products/
Redirect 301 /category/dildos/ /products/
